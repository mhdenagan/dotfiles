#!/bin/sh
# A dmenu wrapper script for system functions.
case "$(readlink -f /sbin/init)" in
	*systemd*) ctl='systemctl' ;;
	*) ctl='loginctl' ;;
esac

case "$(printf "рҹ”’ lock\nрҹҡӘ leave dwm\nвҷ»пёҸ renew dwm\nрҹҗ» hibernate\nрҹ”ғ reboot\nрҹ–ҘпёҸshutdown\nрҹ’Ө sleep\nрҹ“ә display off" | dmenu -fn 'LiberationSans:size=9' -nb '#000000' -i -p 'Action: ')" in
	'рҹ”’ lock') slock ;;
	'рҹҡӘ leave dwm') kill -TERM "$(pgrep -u "$USER" "\bdwm$")" ;;
	'вҷ»пёҸ renew dwm') kill -HUP "$(pgrep -u "$USER" "\bdwm$")" ;;
	'рҹҗ» hibernate') slock $ctl hibernate ;;
	'рҹ’Ө sleep') slock $ctl suspend ;;
	'рҹ”ғ reboot') $ctl reboot -i ;;
	'рҹ–ҘпёҸshutdown') $ctl poweroff -i ;;
	'рҹ“ә display off') xset dpms force off ;;
	*) exit 1 ;;
esac

    include "gr(simple)"

    name[Group1] = "Greek (extended)";

    key.type[Group1] = "THREE_LEVEL";

    key <TLDE> { [ NoSymbol, NoSymbol,  U2015 ] }; // вАХ
    key <AB01> { [ NoSymbol, NoSymbol,  U00A7 ] }; // ¬І

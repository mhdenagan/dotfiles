    key <AD06> { [ NoSymbol, NoSymbol,       U00A5 ] }; // ¬•
    key <AE10> { [ NoSymbol, NoSymbol,         degree ] }; // ¬∞
    key <AE11> { [ NoSymbol, NoSymbol,      plusminus ] }; // ¬±

    key <AD01> { [ NoSymbol, NoSymbol, periodcentered ] }; // ¬Ј
    key <AD04> { [ NoSymbol, NoSymbol,     registered ] }; // ¬Ѓ

    key <AB03> { [ NoSymbol, NoSymbol,      copyright ] }; // ¬©
    key <AB08> { [ NoSymbol, NoSymbol,  guillemotleft ] }; // ¬Ђ
    key <AB09> { [ NoSymbol, NoSymbol, guillemotright ] }; // ¬ї

    include "level3(ralt_switch)"
    include "eurosign(5)"
    include "eurosign(e)"
};

